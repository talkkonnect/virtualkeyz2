            },
            "url": "{{baseUrl}}/api/v1/acl/exception-dates"
          }
        },
        {
          "name": "Delete exception date by row id",
          "request": { "method": "DELETE", "header": [], "url": "{{baseUrl}}/api/v1/acl/exception-dates/{{rowId}}" }
