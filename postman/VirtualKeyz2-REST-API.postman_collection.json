        },
        {
          "name": "Put elevator floor label",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"floor_name\": \"Ground\",\n  \"relay_pin\": 5\n}" },
            "url": "{{baseUrl}}/api/v1/acl/elevator-floor-labels/{{elevatorId}}/0"
          }
        },
        {
          "name": "Delete elevator floor label",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/v1/acl/elevator-floor-labels/{{elevatorId}}/0"
          }
        },
        {
          "name": "List elevator floor groups",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/v1/acl/elevator-floor-groups" }
