	// Sends regular heartbeat via API informing central server it is online [cite: 9]
	ticker := time.NewTicker(ctx.Config.HeartbeatInterval)
	for range ticker.C {
		log.Println("DEBUG: Sending heartbeat to central server...")
		// Implement HTTP POST to central server API
	}
}

func startWebServer(ctx *AppContext) *http.Server {
	router := gin.Default()

	// REST API with Token Support & ACL [cite: 7]
	api := router.Group("/api")
	api.Use(TokenAuthMiddleware())
	{
		api.POST("/remote-control", func(c *gin.Context) {
			// Trigger GPIO based on remote REST command [cite: 7]
			c.JSON(http.StatusOK, gin.H{"status": "door_opened"})
		})
	}

	// Local Web Interface for Config and Monitoring
	router.GET("/admin", func(c *gin.Context) {
		c.String(http.StatusOK, "Local Configuration Interface")
	})

	srv := &http.Server{
		Addr:    ":8080",
		Handler: router,
	}
	go func() {
		log.Println("INFO: Starting Web Server on port 8080")
		if err := srv.ListenAndServe(); err != nil && !errors.Is(err, http.ErrServerClosed) {
			log.Printf("CRITICAL: Web server: %v", err)
		}
	}()
	return srv
}

func monitorDoorSensors(ctx *AppContext) {
	if ctx.GPIO == nil {
		log.Println("INFO: Door sensor monitor disabled (GPIO not available).")
		return
	}
	if !ctx.GPIO.DoorSensorConfigured() {
		log.Println("INFO: Door sensor monitor disabled (no door sensor pin configured).")
		return
	}

	warnAfter := ctx.Config.DoorOpenWarningAfter
	if warnAfter <= 0 {
		warnAfter = 10 * time.Second
	}

	tick := time.NewTicker(100 * time.Millisecond)
	defer tick.Stop()

	var openSince time.Time
	var warned bool
	first := true
	var wasOpen bool

	for range tick.C {
		open := ctx.GPIO.DoorIsOpen(ctx.Config.DoorSensorClosedIsLow)

		if first {
			first = false
			wasOpen = open
			if open {
				log.Printf("INFO: Door status: OPEN (sensor GPIO %d).", ctx.GPIOSettings.DoorSensorPin)
				openSince = time.Now()
			} else {
				log.Printf("INFO: Door status: CLOSED (sensor GPIO %d).", ctx.GPIOSettings.DoorSensorPin)
				openSince = time.Time{}
			}
			warned = false
		} else if open != wasOpen {
			wasOpen = open
			if open {
				log.Printf("INFO: Door is now OPEN (sensor GPIO %d).", ctx.GPIOSettings.DoorSensorPin)
				openSince = time.Now()
				warned = false
			} else {
				log.Printf("INFO: Door is now CLOSED (sensor GPIO %d).", ctx.GPIOSettings.DoorSensorPin)
				openSince = time.Time{}
				warned = false
			}
		}

		if !open {
			continue
		}
		if openSince.IsZero() {
			openSince = time.Now()
		}
		if warned {
			continue
		}
		if time.Since(openSince) >= warnAfter {
			log.Printf("WARNING: Door open longer than %v (door sensor GPIO %d).", warnAfter, ctx.GPIOSettings.DoorSensorPin)
			warned = true
		}
	}
}

// pinMaskLineWidth is the column where the rightmost asterisk is placed (right-aligned mask).
const pinMaskLineWidth = 80

func displayController(ctx *AppContext) {
	// Manages DSI screen, displays greeting messages [cite: 3, 9]
	// Displays random QR code for external mobile phone interaction
	for n := range ctx.PinDisplayDigits {
		if n <= 0 {
			continue
		}
		mask := strings.Repeat("*", n)
		log.Printf("DEBUG: Pin Digits Count %s", mask)
	}
}

// playSoundSync plays a WAV via ALSA aplay; blocks until finished.
func playSoundSync(cfg DeviceConfig, path string) {
	if path == "" {
		return
	}
	if _, err := os.Stat(path); err != nil {
		log.Printf("DEBUG: sound skipped (not found): %s", path)
		return
	}
	args := []string{"-q"}
	if cfg.SoundCardName != "" {
		args = append(args, "-D", cfg.SoundCardName)
	}
	args = append(args, path)
	cmd := exec.Command("aplay", args...)
	if err := cmd.Run(); err != nil {
		log.Printf("WARNING: aplay failed for %s: %v", path, err)
	}
}

func playSoundAsync(cfg DeviceConfig, path string) {
	if path == "" {
		return
	}
	go playSoundSync(cfg, path)
}

func manageHardwareHeartbeat(bcm uint8) {
	// Blinks onboard heartbeat LED to indicate software is running
	pin := rpio.Pin(bcm)
	pin.Output()
	for {
		pin.Toggle()
		time.Sleep(500 * time.Millisecond)
	}
}

func isAllDigits(s string) bool {
	for _, r := range s {
		if !unicode.IsDigit(r) {
			return false
		}
	}
	return len(s) > 0
}

func pinDigitCount(pin string) int {
	n := 0
	for _, r := range pin {
		if unicode.IsDigit(r) {
			n++
		}
	}
	return n
}

func notifyPinDisplay(ctx *AppContext, pin string) {
	if ctx.PinDisplayDigits == nil {
		return
	}
	ctx.PinDisplayDigits <- pinDigitCount(pin)
}

func TokenAuthMiddleware() gin.HandlerFunc {
	return func(c *gin.Context) {
		// Validates tokens for the REST HTTP API [cite: 7]
		c.Next()
	}
}

// Use evtest in linux to test the capabilities of the keypad
func startNumpadListener(ctx *AppContext) {
	// In a production environment, the device path should be loaded from your ctx.Config
	// You can find the correct event file by running `cat /proc/bus/input/devices` on the Pi
	devicePath := "/dev/input/event1"

	dev, err := evdev.Open(devicePath)
	if err != nil {
		log.Printf("CRITICAL: Failed to open USB keypad at %s: %v", devicePath, err)
		return
	}
	defer dev.File.Close()

	log.Printf("INFO: Listening to USB Keypad: %s", dev.Name)

	var pinBuffer string

	// Timeout configuration for the keypad as defined in your specs
	keyTimeout := 5 * time.Second
	timer := time.NewTimer(keyTimeout)
	timer.Stop()

	for {
		// ReadOne blocks until an event occurs
		ev, err := dev.ReadOne()
		if err != nil {
			log.Printf("ERROR: Failed to read from keypad: %v", err)
			time.Sleep(1 * time.Second) // Prevent tight loop on hardware failure
			continue
		}

		// We only process Key events (EV_KEY) and specifically Key Press/Down events (Value 1)
		if ev.Type == evdev.EV_KEY && ev.Value == 1 {
			// Reset the timeout timer on every valid keypress
			timer.Reset(keyTimeout)
			playSoundSync(ctx.Config, ctx.Config.SoundKeypress)

			ke := evdev.NewKeyEvent(ev)
			char := ""

			// Map standard Keypad and standard Number Scancodes
			switch ke.Scancode {
			case evdev.KEY_KP0, evdev.KEY_0:
				char = "0"
				log.Println("DEBUG: Keypad 0 pressed")
			case evdev.KEY_KP1, evdev.KEY_1:
				char = "1"
				log.Println("DEBUG: Keypad 1 pressed")
			case evdev.KEY_KP2, evdev.KEY_2:
				char = "2"
				log.Println("DEBUG: Keypad 2 pressed")
			case evdev.KEY_KP3, evdev.KEY_3:
				char = "3"
				log.Println("DEBUG: Keypad 3 pressed")
			case evdev.KEY_KP4, evdev.KEY_4:
				char = "4"
				log.Println("DEBUG: Keypad 4 pressed")
			case evdev.KEY_KP5, evdev.KEY_5:
				char = "5"
				log.Println("DEBUG: Keypad 5 pressed")
			case evdev.KEY_KP6, evdev.KEY_6:
				char = "6"
				log.Println("DEBUG: Keypad 6 pressed")
			case evdev.KEY_KP7, evdev.KEY_7:
				char = "7"
				log.Println("DEBUG: Keypad 7 pressed")
			case evdev.KEY_KP8, evdev.KEY_8:
				char = "8"
				log.Println("DEBUG: Keypad 8 pressed")
			case evdev.KEY_KP9, evdev.KEY_9:
				char = "9"
				log.Println("DEBUG: Keypad 9 pressed")
			case evdev.KEY_KPSLASH, evdev.KEY_SLASH:
				char = "/"
				log.Println("DEBUG: Keypad Slash pressed")
			case evdev.KEY_KPMINUS:
				char = "-"
				log.Println("DEBUG: Keypad Minus pressed")
			case evdev.KEY_KPPLUS:
				char = "+"
				log.Println("DEBUG: Keypad Plus pressed")
			case evdev.KEY_KPDOT:
				char = "."
				log.Println("DEBUG: Keypad Dot pressed")
			case evdev.KEY_BACKSPACE:
				if len(pinBuffer) > 0 {
					pinBuffer = pinBuffer[:len(pinBuffer)-1]
				}
				notifyPinDisplay(ctx, pinBuffer)
			case evdev.KEY_KPENTER, evdev.KEY_ENTER:
				// Submit PIN
				log.Printf("INFO: PIN submission initiated.")
				processPIN(ctx, pinBuffer)
				pinBuffer = ""
				timer.Stop()
				notifyPinDisplay(ctx, pinBuffer)
			case evdev.KEY_KPASTERISK:
				// Execute the "Call for help" function from your specifications
				log.Println("INFO: 'Call for Help' triggered via USB keypad.")
				triggerCallForHelp(ctx)
				pinBuffer = ""
				timer.Stop()
				notifyPinDisplay(ctx, pinBuffer)
			}

			if char != "" {
				pinBuffer += char
				notifyPinDisplay(ctx, pinBuffer)

				if ctx.Config.PinLength > 0 && len(pinBuffer) >= ctx.Config.PinLength && isAllDigits(pinBuffer) {
					log.Printf("INFO: PIN auto-submitted after %d digits.", ctx.Config.PinLength)
					processPIN(ctx, pinBuffer)
					pinBuffer = ""
					timer.Stop()
					notifyPinDisplay(ctx, pinBuffer)
				}
			}
		}

		// Check if the timer has expired to clear the buffer
		select {
		case <-timer.C:
			if len(pinBuffer) > 0 {
				log.Println("DEBUG: Keypad entry timed out. Clearing buffer.")
				pinBuffer = ""
				notifyPinDisplay(ctx, pinBuffer)
			}
		default:
			// Non-blocking default allows the loop to continue instantly
		}
	}
}

const validAccessPIN = "123456"

func processPIN(ctx *AppContext, pin string) {
	// Query local SQLite for permissions
	// Validate PIN against door constraints
	// Trigger Relay, Sound Event, MQTT Update, and Logging
	log.Printf("DEBUG: Processing PIN: %s", pin)
	if pin == validAccessPIN {
		ctx.pinFailMu.Lock()
		ctx.pinFailSeq = 0
		ctx.pinFailMu.Unlock()

		log.Printf("INFO: PIN accepted; pulsing door relay (GPIO %d).", ctx.GPIOSettings.DoorRelayPin)
		playSoundSync(ctx.Config, ctx.Config.SoundPinOK)
		if ctx.GPIO != nil {
			ctx.GPIO.ActionPulse("door", ctx.Config.RelayPulseDuration)
		} else {
			log.Println("WARNING: GPIO unavailable; relay pulse skipped.")
		}
		return
	}

	log.Println("INFO: PIN rejected.")
	playSoundSync(ctx.Config, ctx.Config.SoundPinReject)

	ctx.pinFailMu.Lock()
	ctx.pinFailSeq++
	failCount := ctx.pinFailSeq
	threshold := ctx.Config.PinRejectBuzzerAfterAttempts
	ctx.pinFailMu.Unlock()

	if threshold <= 0 || failCount < threshold {
		return
	}

	ctx.pinFailMu.Lock()
	ctx.pinFailSeq = 0
	ctx.pinFailMu.Unlock()

	log.Printf("INFO: Wrong PIN threshold reached (%d); pulsing buzzer relay (GPIO %d).", threshold, ctx.GPIOSettings.BuzzerRelayPin)
	if ctx.GPIO != nil {
		ctx.GPIO.ActionPulse("buzzer", ctx.Config.BuzzerRelayPulseDuration)
	} else {
		log.Println("WARNING: GPIO unavailable; buzzer relay pulse skipped.")
	}
}

